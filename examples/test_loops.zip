// Test: Loop control - break and continue
fn main() -> int {
    // Test 1: while loop with break
    let i: int = 0;
    while i < 10 {
        if i == 5 {
            break;
        }
        print(i);  // 0 1 2 3 4
        i = i + 1;
    }
    
    // Test 2: while loop with continue
    let j: int = 0;
    while j < 5 {
        j = j + 1;
        if j % 2 == 0 {
            continue;
        }
        print(j);  // 1 3 5
    }
    
    // Test 3: for loop with break
    for let k: int = 0; k < 10; k = k + 1 {
        if k == 3 {
            break;
        }
        print(k);  // 0 1 2
    }
    
    // Test 4: for loop with continue
    for let m: int = 0; m < 5; m = m + 1 {
        if m == 2 {
            continue;
        }
        print(m);  // 0 1 3 4
    }
    
    return 0;
}

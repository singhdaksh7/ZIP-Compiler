// Test: Basic arithmetic operations
fn main() -> int {
    let a: int = 10;
    let b: int = 3;
    let sum: int = a + b;
    let diff: int = a - b;
    let prod: int = a * b;
    let quot: int = a / b;
    let rem: int = a % b;
    
    print(sum);   // 13
    print(diff);  // 7
    print(prod);  // 30
    print(quot);  // 3
    print(rem);   // 1
    
    return 0;
}

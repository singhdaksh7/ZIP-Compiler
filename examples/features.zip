// features.zip — showcases all ZIP language features

fn factorial(n: int) -> int {
    if n <= 1 {
        return 1;
    }
    return n * factorial(n - 1);
}

fn max(a: int, b: int) -> int {
    if a > b {
        return a;
    }
    return b;
}

fn main() -> int {
    // --- Variables and arithmetic ---
    let x: int = 10;
    let y: int = 3;
    print(x + y);
    print(x - y);
    print(x * y);
    print(x / y);
    print(x % y);

    // --- Comparisons and booleans ---
    let eq: bool = x == 10;
    let lt: bool = y < x;
    print(eq);
    print(lt);

    // --- Function calls ---
    let f5: int = factorial(5);
    print(f5);

    let bigger: int = max(7, 42);
    print(bigger);

    // --- If / else if / else ---
    let score: int = 75;
    if score >= 90 {
        print(1);
    } else if score >= 60 {
        print(2);
    } else {
        print(3);
    }

    // --- While loop with continue ---
    let i: int = 0;
    while i < 10 {
        i = i + 1;
        if i % 2 == 0 {
            continue;
        }
        print(i);
    }

    // --- For loop with break ---
    for let j: int = 0; j < 100; j = j + 1 {
        if j == 5 {
            break;
        }
        print(j);
    }

    // --- String printing ---
    let greeting: string = "Hello, ZIP!";
    print(greeting);

    // --- Unary operators ---
    let neg: int = -42;
    print(neg);
    let flag: bool = !eq;
    print(flag);

    // --- Nested loops ---
    let a: int = 0;
    while a < 3 {
        let b: int = 0;
        while b < 3 {
            print(a * 3 + b);
            b = b + 1;
        }
        a = a + 1;
    }

    return 0;
}

// Hello World in ZIP
// This is the first ZIP program!

fn main() -> int {
    let x: int = 42;
    let y: int = 10;
    let sum: int = x + y;

    print(sum);

    // Conditional
    if sum >= 50 {
        print(1);
    } else {
        print(0);
    }

    // Loop: print 0 to 4
    let i: int = 0;
    while i < 5 {
        print(i);
        i = i + 1;
    }

    return 0;
}

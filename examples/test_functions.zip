// Test: Function calls with multiple parameters
fn add(a: int, b: int) -> int {
    return a + b;
}

fn multiply(a: int, b: int) -> int {
    return a * b;
}

fn power(base: int, exp: int) -> int {
    let result: int = 1;
    let i: int = 0;
    while i < exp {
        result = result * base;
        i = i + 1;
    }
    return result;
}

fn sum_three(a: int, b: int, c: int) -> int {
    return a + b + c;
}

fn main() -> int {
    let s1: int = add(5, 3);           // 8
    let s2: int = multiply(4, 7);      // 28
    let s3: int = power(2, 10);        // 1024
    let s4: int = sum_three(1, 2, 3);  // 6
    
    print(s1);  // 8
    print(s2);  // 28
    print(s3);  // 1024
    print(s4);  // 6
    
    return 0;
}
